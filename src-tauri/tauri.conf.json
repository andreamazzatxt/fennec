{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Fennec",
  "version": "0.5.2",
  "identifier": "ai.fennec.app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "cargo build --manifest-path fennec-tap/Cargo.toml --release && bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "id": "fennec-tray",
      "iconPath": "icons/tray_color.png",
      "iconAsTemplate": false,
      "tooltip": "Fennec"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "resources": {
      "../target/release/fennec-tap": "fennec-tap"
    },
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhCNDFDODU4MjhGMUQ0MEUKUldRTzFQRW9XTWhCaXlkVklpbEdhVzlsaWIvdmxpaEtTMncyY24zS2E0RFlUWGhzR083bXIvR0YK",
      "endpoints": [
        "https://github.com/andreamazzatxt/fennec/releases/latest/download/latest.json"
      ]
    }
  }
}
